<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="../stylesheets/style.css">
</head>
<body>
    <div class="settings-panel">
  <label for="radiusSlider">
    Circle Radius
    <span id="radiusValue">70vmin</span>
  </label>
  <input type="range" id="radiusSlider" min="30" max="150" value="70">
</div>

<div class="hero-sticky-container">

  <div class="image-ring" id="rotatingRing">
    <img style="--i: 0;" src="https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?q=80&w=600&auto=format&fit=crop" alt="Abstract Art">
    <img style="--i: 1;" src="https://images.unsplash.com/photo-1549490349-8643362247b5?q=80&w=600&auto=format&fit=crop" alt="3D Render">
    <img style="--i: 2;" src="https://images.unsplash.com/photo-1604871000636-074fa5117945?q=80&w=600&auto=format&fit=crop" alt="Abstract Shapes">
    <img style="--i: 3;" src="https://images.unsplash.com/photo-1550684848-fac1c5b4e853?q=80&w=600&auto=format&fit=crop" alt="Architecture">
    <img style="--i: 4;" src="https://images.unsplash.com/photo-1529336953128-a85760f58cb5?q=80&w=600&auto=format&fit=crop" alt="Nature Plant">
    <img style="--i: 5;" src="https://images.unsplash.com/photo-1507608616759-54f48f0af0ee?q=80&w=600&auto=format&fit=crop" alt="Rainy City">
    <img style="--i: 6;" src="https://images.unsplash.com/photo-1518531933037-91b2f5f229cc?q=80&w=600&auto=format&fit=crop" alt="Tree landscape">
    <img style="--i: 7;" src="https://images.unsplash.com/photo-1614850523459-c2f4c699c52e?q=80&w=600&auto=format&fit=crop" alt="3D Glass">
    <img style="--i: 8;" src="https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?q=80&w=600&auto=format&fit=crop" alt="Mountains">
    <img style="--i: 9;" src="https://images.unsplash.com/photo-1660404731889-a2c3eba56b27?q=80&w=1974&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" alt="Liquid Abstract">
  </div>

  <div class="content-wrapper">
    <div class="center-content">
      <h1>Create Stunning AI Generated<br>Photos Instantly</h1>
      <p class="subtitle">Transform your ideas into breathtaking visuals with cutting-edge AI technology.</p>
      <button class="cta-button">
        Start Generating Now
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </button>
    </div>

    <div class="features">
      <div class="feature-item">
        <h3>Realistic Results</h3>
        <p>Photos that look<br>professionally crafted.</p>
      </div>
      <div class="feature-item">
        <h3>Fast Generation</h3>
        <p>Turn ideas into<br>images in seconds.</p>
      </div>
      <div class="feature-item">
        <h3>Diverse Styles</h3>
        <p>Choose from a wide range<br>of artistic options.</p>
      </div>
    </div>
  </div>

  <div class="scroll-indicator">Scroll Down &darr;</div>
</div>
<script src="/javascripts/script.js"></script>
</body>
</html>